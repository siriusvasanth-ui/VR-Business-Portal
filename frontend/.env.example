# Base URL of the backend API.
# Leave EMPTY for local dev (Vite proxies /api to http://localhost:5000)
# and for single-service Render deploys (frontend served by the backend).
# Set to the backend URL for a split deployment, e.g.
#   VITE_API_BASE_URL=https://vr-business-portal-api.onrender.com
VITE_API_BASE_URL=
